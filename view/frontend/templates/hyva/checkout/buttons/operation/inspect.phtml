<?php
/** @var \Punchout\Gateway\Block\Checkout\Buttons\Operation\Inspect $block */
$cancelUrl = $block->getCancelUrl();
$isInitiallyDisabled = $block->isDisabled();
?>

<div class="punchout-actions flex flex-col gap-4" 
     x-data="punchoutInspect('<?= $block->escapeUrl($cancelUrl) ?>', <?= $isInitiallyDisabled ? 'true' : 'false' ?>)">
    
    <button type="button"
            @click="processReturn"
            :disabled="isLoading || isHardDisabled"
            :class="{ 'opacity-50 cursor-not-allowed': isLoading || isHardDisabled }"
            class="action primary btn btn-primary w-full justify-center">
        <span x-show="!isLoading"><?= $block->escapeHtml(__('Cancel & Return')) ?></span>
        <span x-show="isLoading"><?= $block->escapeHtml(__('Returning...')) ?></span>
    </button>
</div>